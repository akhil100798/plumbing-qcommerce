# Core service
SERVER_PORT=8081
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/plumbing_commerce
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=local-postgres-password
SPRING_DATA_MONGODB_URI=mongodb://admin:local-mongo-password@localhost:27017/plumbing_commerce?authSource=admin
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
JWT_SECRET=replace-with-a-local-development-key-at-least-32-bytes

# Edge service
PORT=3000
REDIS_HOST=localhost
REDIS_PORT=6379
KAFKA_BROKER=localhost:9092
CORE_API_URL=http://localhost:8081

# Browser and mobile clients
NEXT_PUBLIC_CORE_API_URL=http://localhost:8081
NEXT_PUBLIC_EDGE_URL=http://localhost:3000
EXPO_PUBLIC_CORE_API_URL=http://10.0.2.2:8081
EXPO_PUBLIC_EDGE_URL=http://10.0.2.2:3000

# Docker Compose data stores
POSTGRES_DB=plumbing_commerce
POSTGRES_USER=admin
POSTGRES_PASSWORD=local-postgres-password
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=local-mongo-password
